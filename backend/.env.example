# Neo4j Aura Connection
# Get these from your Neo4j Aura console: https://console.neo4j.io
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-secure-password-here
NEO4J_DATABASE=neo4j

# Firebase Admin SDK (optional - for server-side token verification)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS=./firebase-service-account.json

# Or use project ID for default credentials
FIREBASE_PROJECT_ID=your-firebase-project-id

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000

# Debug Mode - NEVER set to true in production
DEBUG_MODE=false

# Email Service (Resend)
# Get API key from: https://resend.com/api-keys
EMAIL_ENABLED=false
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=KinetiK <notifications@kinetik.app>
EMAIL_REPLY_TO=support@kinetik.app
